<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template XLSX da ficha de cliente.
  Estrutura: o título traz um bloco label/valor com os dados do cliente (uma única
  vez), o columnHeader traz os cabeçalhos das colunas de endereço e o detail repete
  uma linha por endereço. Todas as posições X compartilham o mesmo grid de 9 colunas
  para que o JRXlsxExporter gere uma planilha sem colunas mescladas indevidamente.
-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RelatorioClienteDetalheXlsx"
              pageWidth="800" pageHeight="842" columnWidth="800"
              leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0"
              uuid="d720d812-be14-4a9a-ae44-000000000020">

	<property name="net.sf.jasperreports.export.xls.one.page.per.sheet" value="false"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.rows" value="true"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.columns" value="true"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.white.page.background" value="false"/>

	<parameter name="clienteId" class="java.lang.String"/>

	<queryString language="SQL">
		<![CDATA[SELECT
    c.email,
    c.tipo_pessoa,
    CASE WHEN c.ativo = 1 THEN 'Sim' ELSE 'Não' END AS ativo,
    COALESCE(pf.nome, pj.razao_social) AS nome_razao,
    COALESCE(pf.cpf, pj.cnpj) AS documento,
    pf.rg,
    pf.data_nascimento,
    pj.inscricao_estadual,
    pj.data_criacao,
    e.logradouro,
    e.numero,
    e.complemento,
    e.bairro,
    e.cep,
    e.telefone,
    e.cidade,
    e.estado,
    CASE WHEN e.endereco_principal = 1 THEN 'Sim' ELSE 'Não' END AS principal
FROM desafio_estagio.clientes c
LEFT JOIN desafio_estagio.clientes_pf pf ON c.id = pf.id
LEFT JOIN desafio_estagio.clientes_pj pj ON c.id = pj.id
LEFT JOIN desafio_estagio.enderecos e ON c.id = e.cliente_id
WHERE c.id = UUID_TO_BIN($P{clienteId})]]>
	</queryString>

	<field name="email" class="java.lang.String"/>
	<field name="tipo_pessoa" class="java.lang.String"/>
	<field name="ativo" class="java.lang.String"/>
	<field name="nome_razao" class="java.lang.String"/>
	<field name="documento" class="java.lang.String"/>
	<field name="rg" class="java.lang.String"/>
	<field name="data_nascimento" class="java.sql.Date"/>
	<field name="inscricao_estadual" class="java.lang.String"/>
	<field name="data_criacao" class="java.sql.Date"/>
	<field name="logradouro" class="java.lang.String"/>
	<field name="numero" class="java.lang.String"/>
	<field name="complemento" class="java.lang.String"/>
	<field name="bairro" class="java.lang.String"/>
	<field name="cep" class="java.lang.String"/>
	<field name="telefone" class="java.lang.String"/>
	<field name="cidade" class="java.lang.String"/>
	<field name="estado" class="java.lang.String"/>
	<field name="principal" class="java.lang.String"/>

	<title>
		<band height="220">
			<!-- Cabeçalho de seção: ocupa toda a largura, mesclando todas as 9 colunas no XLSX. -->
			<staticText>
				<reportElement mode="Opaque" x="0" y="0" width="800" height="22" backcolor="#006699" forecolor="#FFFFFF" uuid="fe010000-0000-0000-0000-000000000001"/>
				<textElement textAlignment="Left" verticalAlignment="Middle"><font size="11" isBold="true"/></textElement>
				<text><![CDATA[ DADOS DO CLIENTE]]></text>
			</staticText>

			<!-- 9 linhas label/valor. Label na col 1 (x=0 w=160), valor mesclado nas cols 2-9 (x=160 w=640). -->
			<staticText>
				<reportElement mode="Opaque" x="0"   y="22" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000002"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ Nome / Razão Social]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement x="160" y="22" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000003"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{nome_razao}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement mode="Opaque" x="0"   y="42" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000004"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ Tipo de Pessoa]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement x="160" y="42" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000005"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{tipo_pessoa}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement mode="Opaque" x="0"   y="62" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000006"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ E-mail]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement x="160" y="62" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000007"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement mode="Opaque" x="0"   y="82" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000008"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ Documento (CPF / CNPJ)]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement x="160" y="82" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000009"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{documento}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement mode="Opaque" x="0"   y="102" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000010"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ RG]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement x="160" y="102" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000011"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{rg}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement mode="Opaque" x="0"   y="122" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000012"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ Data de Nascimento]]></text>
			</staticText>
			<textField pattern="dd/MM/yyyy" isBlankWhenNull="true">
				<reportElement x="160" y="122" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000013"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{data_nascimento}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement mode="Opaque" x="0"   y="142" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000014"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ Inscrição Estadual]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement x="160" y="142" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000015"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{inscricao_estadual}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement mode="Opaque" x="0"   y="162" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000016"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ Data de Criação da Empresa]]></text>
			</staticText>
			<textField pattern="dd/MM/yyyy" isBlankWhenNull="true">
				<reportElement x="160" y="162" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000017"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{data_criacao}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement mode="Opaque" x="0"   y="182" width="160" height="20" backcolor="#E6E6E6" uuid="fe010000-0000-0000-0000-000000000018"/>
				<textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
				<text><![CDATA[ Ativo]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement x="160" y="182" width="640" height="20" uuid="fe010000-0000-0000-0000-000000000019"/>
				<textElement verticalAlignment="Middle"><font size="9"/></textElement>
				<textFieldExpression><![CDATA[$F{ativo}]]></textFieldExpression>
			</textField>

			<!-- Banner da seção de endereços, também ocupa todas as 9 colunas. -->
			<staticText>
				<reportElement mode="Opaque" x="0" y="202" width="800" height="18" backcolor="#006699" forecolor="#FFFFFF" uuid="fe010000-0000-0000-0000-000000000020"/>
				<textElement textAlignment="Left" verticalAlignment="Middle"><font size="11" isBold="true"/></textElement>
				<text><![CDATA[ ENDEREÇOS]]></text>
			</staticText>
		</band>
	</title>

	<columnHeader>
		<band height="22">
			<staticText>
				<reportElement mode="Opaque" x="0"   y="0" width="160" height="22" backcolor="#E6E6E6" forecolor="#006699" uuid="fe020000-0000-0000-0000-000000000001"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<text><![CDATA[Logradouro]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="160" y="0" width="40"  height="22" backcolor="#E6E6E6" forecolor="#006699" uuid="fe020000-0000-0000-0000-000000000002"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<text><![CDATA[Nº]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="200" y="0" width="120" height="22" backcolor="#E6E6E6" forecolor="#006699" uuid="fe020000-0000-0000-0000-000000000003"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<text><![CDATA[Complemento]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="320" y="0" width="100" height="22" backcolor="#E6E6E6" forecolor="#006699" uuid="fe020000-0000-0000-0000-000000000004"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<text><![CDATA[Bairro]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="420" y="0" width="80"  height="22" backcolor="#E6E6E6" forecolor="#006699" uuid="fe020000-0000-0000-0000-000000000005"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<text><![CDATA[CEP]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="500" y="0" width="100" height="22" backcolor="#E6E6E6" forecolor="#006699" uuid="fe020000-0000-0000-0000-000000000006"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<text><![CDATA[Telefone]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="600" y="0" width="100" height="22" backcolor="#E6E6E6" forecolor="#006699" uuid="fe020000-0000-0000-0000-000000000007"/>
				<textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
				<text><![CDATA[Cidade]]></text>
